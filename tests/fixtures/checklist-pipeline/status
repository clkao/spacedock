#!/bin/bash
# ABOUTME: Status viewer for the checklist-pipeline test fixture.
# ABOUTME: Displays task status from YAML frontmatter; supports --next for dispatch detection.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
  echo "Usage: $0 [--next]" >&2
  exit 2
}

want_next=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --next) want_next=1; shift ;;
    -h|--help) usage ;;
    *) usage ;;
  esac
done

printf "%-25s %-10s %-30s %-7s %-10s\n" "slug" "status" "title" "score" "source"
printf "%-25s %-10s %-30s %-7s %-10s\n" "----" "------" "-----" "-----" "------"

dispatchable=()

for file in "$SCRIPT_DIR"/*.md; do
  [[ "$(basename "$file")" == "README.md" ]] && continue
  slug="$(basename "$file" .md)"
  status=""
  title=""
  score=""
  source=""

  in_fm=0
  while IFS= read -r line; do
    if [[ "$line" == "---" ]]; then
      if [[ $in_fm -eq 0 ]]; then in_fm=1; continue; else break; fi
    fi
    [[ $in_fm -eq 0 ]] && continue
    key="${line%%:*}"
    val="${line#*:}"
    val="${val# }"
    case "$key" in
      title) title="$val" ;;
      status) status="$val" ;;
      score) score="$val" ;;
      source) source="$val" ;;
    esac
  done < "$file"

  printf "%-25s %-10s %-30s %-7s %-10s\n" "$slug" "$status" "$title" "$score" "$source"

  if [[ "$status" == "backlog" ]]; then
    dispatchable+=("$slug")
  fi
done

if [[ $want_next -eq 1 ]]; then
  if [[ ${#dispatchable[@]} -gt 0 ]]; then
    echo
    echo "DISPATCHABLE:"
    for slug in "${dispatchable[@]}"; do
      echo "- $slug"
    done
  fi
fi

